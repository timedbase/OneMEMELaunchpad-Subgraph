{
  "name": "onememe-launchpad-subgraph",
  "version": "1.0.0",
  "description": "The Graph subgraph for OneMEME Launchpad on BNB Smart Chain",
  "scripts": {
    "codegen": "graph codegen subgraph.bsc.yaml",
    "build": "graph build subgraph.bsc.yaml",
    "deploy": "graph deploy subgraph.bsc.yaml",

    "codegen:bsc": "graph codegen subgraph.bsc.yaml",
    "build:bsc": "graph build subgraph.bsc.yaml",
    "deploy:bsc": "graph deploy subgraph.bsc.yaml",

    "codegen:ethereum": "graph codegen subgraph.ethereum.yaml",
    "build:ethereum": "graph build subgraph.ethereum.yaml",
    "deploy:ethereum": "graph deploy subgraph.ethereum.yaml",

    "create-local": "graph create --node http://localhost:8020/ onememe/launchpad",
    "remove-local": "graph remove --node http://localhost:8020/ onememe/launchpad",
    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 onememe/launchpad"
  },
  "dependencies": {
    "@graphprotocol/graph-ts": "^0.35.1"
  },
  "devDependencies": {
    "@graphprotocol/graph-cli": "^0.81.0",
    "matchstick-as": "^0.6.0"
  }
}
